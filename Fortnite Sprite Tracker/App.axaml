<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FortniteSpriteTracker.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://FortniteSpriteTracker/Styles/AppStyles.axaml"/>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://FortniteSpriteTracker/Styles/DarkTheme.axaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Glass panel brushes — updated at runtime by the opacity slider -->
            <SolidColorBrush x:Key="PanelBrush"    Color="#CC05080D"/>
            <SolidColorBrush x:Key="PanelBrushAlt" Color="#CC0D1621"/>
            <SolidColorBrush x:Key="CardBrush"      Color="#CC213853"/>
        </ResourceDictionary>
    </Application.Resources>

</Application>
