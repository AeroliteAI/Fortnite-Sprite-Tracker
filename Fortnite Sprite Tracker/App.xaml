<Application x:Class="FortniteSpriteTracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Defined here (not in DarkTheme.xaml) so slider updates via
                 Application.Current.Resources reach ALL windows, including
                 OptionsWindow which has its own local DarkTheme.xaml merge. -->
            <SolidColorBrush x:Key="PanelBrush"    Color="#CC05080D"/>
            <SolidColorBrush x:Key="PanelBrushAlt" Color="#CC0D1621"/>
            <SolidColorBrush x:Key="CardBrush"      Color="#CC213853"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
