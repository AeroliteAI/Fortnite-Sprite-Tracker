<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FortniteSpriteTracker.Models"
        x:Class="FortniteSpriteTracker.Views.OptionsWindow"
        Title="Options — Sprite Tracker"
        Width="560" Height="560"
        MinWidth="480" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        TextOptions.TextRenderingMode="Antialias"
        CanResize="True"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        WindowDecorations="None">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="#2A2A40" BorderThickness="0,0,0,1"
                Padding="24,16"
                PointerPressed="Header_PointerPressed">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock Text="⚙" Foreground="#7C3AED" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="OPTIONS" Foreground="#E2E8F0" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Classes="captionBtn" Click="Close_Click">
                    <Image Source="/Assets/Close.png" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- Tab strip -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="#2A2A40" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="FilesTabBtn"        Content="FILES"        Classes="tabBtn active" Click="FilesTab_Click"/>
                <Button x:Name="InstructionsTabBtn" Content="INSTRUCTIONS" Classes="tabBtn"        Click="InstructionsTab_Click"/>
                <Button x:Name="PatchNotesTabBtn"   Content="PATCH NOTES"  Classes="tabBtn"        Click="PatchNotesTab_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid>

            <!-- FILES TAB -->
            <ScrollViewer x:Name="FilesPanel"
                          VerticalScrollBarVisibility="Auto"
                          Background="#01000000">
                <StackPanel Margin="28,24,28,24">

                    <TextBlock Text="DATA LOCATIONS" Foreground="#94A3B8" FontSize="10"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="📁" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Sprites Folder" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="SpritesFolderPath" Foreground="#E2E8F0" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,0,0,10" FontFamily="Consolas"/>
                            <Button Content="Open Sprites Folder" Classes="folderBtn" Click="OpenSprites_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="💾" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Data Folder" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="DataFolderPath" Foreground="#E2E8F0" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,0,0,10" FontFamily="Consolas"/>
                            <Button Content="Open Data Folder" Classes="folderBtn" Click="OpenData_Click"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DISPLAY" Foreground="#94A3B8" FontSize="10"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <!-- Badge animation -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Badge Animation" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Animates the SPECIAL rarity badge on cards." Foreground="#64748B" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="On"  Classes="filterBtn"
                                        Classes.active="{Binding AnimateBadges}"
                                        Command="{Binding EnableBadgeAnimationCommand}" Margin="0,0,4,0"/>
                                <Button Content="Off" Classes="filterBtn"
                                        Classes.active="{Binding AnimateBadges, Converter={StaticResource InverseBoolConverter}}"
                                        Command="{Binding DisableBadgeAnimationCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Window opacity -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Window Opacity" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Controls how transparent the panel backgrounds are." Foreground="#64748B" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                <Slider Minimum="10" Maximum="100" SmallChange="5" LargeChange="10"
                                        TickFrequency="5" Value="{Binding PanelOpacity}"
                                        Width="160" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PanelOpacity, StringFormat={}{0}%}"
                                           Foreground="#E2E8F0" FontSize="12" Width="42" TextAlignment="Right"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Stream overlay server -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Stream Overlay Server" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Runs a local server on port 7842 for the OBS browser source." Foreground="#64748B" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="On"  Classes="filterBtn"
                                        Classes.active="{Binding OverlayServerEnabled}"
                                        Command="{Binding EnableOverlayServerCommand}" Margin="0,0,4,0"/>
                                <Button Content="Off" Classes="filterBtn"
                                        Classes.active="{Binding OverlayServerEnabled, Converter={StaticResource InverseBoolConverter}}"
                                        Command="{Binding DisableOverlayServerCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Overlay scroll speed -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Overlay Scroll Speed" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="How fast the stream overlay scrolls through cards." Foreground="#64748B" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                <Slider Minimum="10" Maximum="300" SmallChange="10" LargeChange="50"
                                        TickFrequency="10" Value="{Binding OverlayScrollSpeed}"
                                        Width="160" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding OverlayScrollSpeed, StringFormat={}{0} px/s}"
                                           Foreground="#E2E8F0" FontSize="12" Width="60" TextAlignment="Right"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Overlay output folder -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="📁" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Overlay Output Folder" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="OverlayOutputPathText" Foreground="#E2E8F0" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,0,0,10" FontFamily="Consolas"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Choose Folder" Classes="folderBtn" Click="BrowseOverlayOutput_Click" Margin="0,0,8,0"/>
                                <Button Content="Reset to Default" Classes="folderBtn" Click="ResetOverlayOutput_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- INSTRUCTIONS TAB -->
            <ScrollViewer x:Name="InstructionsPanel"
                          IsVisible="False"
                          VerticalScrollBarVisibility="Auto"
                          Background="#01000000">
                <StackPanel Margin="28,24,28,24">

                    <TextBlock Text="HOW IT WORKS" Foreground="#94A3B8" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Foreground="#CBD5E1" FontSize="12.5" TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,10">
                        Place <Run Foreground="#E2E8F0" FontWeight="SemiBold">.webp</Run> image files in your Sprites folder and hit <Run Foreground="#E2E8F0" FontWeight="SemiBold">Refresh</Run>. The app reads the filename, strips the rarity keyword, and lets you track two states per sprite:
                    </TextBlock>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="✓" Foreground="#4ADE80" FontSize="13" FontWeight="Bold" Width="24"/>
                                <TextBlock Text="Collected" Foreground="#E2E8F0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="24,0,0,12">
                                You own this sprite. Shown with a green border and a ✓ badge.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image x:Name="MasteredIcon" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                <TextBlock Text="Mastered" Foreground="#E2E8F0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="24,0,0,0">
                                You have fully mastered this sprite. Shown with an amber border.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="FILE NAMING SCHEME" Foreground="#94A3B8" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Foreground="#CBD5E1" FontSize="12.5" TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,10">
                        Filenames follow <Run Foreground="#E2E8F0" FontWeight="SemiBold">{Name} {RARITY}.webp</Run> for base sprites and <Run Foreground="#E2E8F0" FontWeight="SemiBold">{Name} {RARITY} {Variant}.webp</Run> for variants.
                    </TextBlock>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10">VALID RARITY KEYWORDS (must be ALL CAPS)</TextBlock>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Background="#1A2A3A" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="RARE" Foreground="#38BDF8" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#2A1A3A" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="EPIC" Foreground="#A855F7" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#3A2A1A" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="LEGENDARY" Foreground="#F97316" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#3A2A00" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="MYTHIC" Foreground="#EAB308" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#1A3A2A" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="SPECIAL" Foreground="#4ADE80" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10">EXAMPLES</TextBlock>
                            <TextBlock Text="Fire RARE.webp"              Foreground="#7C3AED" FontFamily="Consolas" FontSize="12" Margin="0,2,0,2"/>
                            <TextBlock Text="Fire SPECIAL Galaxy.webp"    Foreground="#7C3AED" FontFamily="Consolas" FontSize="12" Margin="0,2,0,8"/>
                            <TextBlock Text="STREAM OVERLAY" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4">
                                • In OBS add a <Run Foreground="#E2E8F0">Browser Source</Run> pointed at <Run Foreground="#E2E8F0">overlay.html</Run> in the app folder.
                            </TextBlock>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap">
                                • Enable the server in Options → Display, then set width/height to match your layout.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- PATCH NOTES TAB -->
            <ScrollViewer x:Name="PatchNotesPanel"
                          IsVisible="False"
                          VerticalScrollBarVisibility="Auto"
                          Background="#01000000">
                <StackPanel Margin="28,24,28,24">

                    <TextBlock Text="CURRENT VERSION" Foreground="#94A3B8" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CurrentVersionText" Foreground="#7C3AED" FontSize="16"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="CHANGELOG" Foreground="#94A3B8" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="PatchNotesItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PatchNoteEntry">
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                       Foreground="#E2E8F0" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Date}"
                                                       Foreground="#64748B" FontSize="11"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:PatchNoteItem">
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
                                                                Background="{Binding Tag, Converter={StaticResource PatchNoteTagToBrushConverter}}"
                                                                CornerRadius="4" Padding="7,3" Margin="0,1,10,0"
                                                                VerticalAlignment="Top" HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Tag}" FontSize="10"
                                                                       FontWeight="Bold" Foreground="#0D0D15"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Text}"
                                                                   Foreground="#CBD5E1" FontSize="12.5"
                                                                   TextWrapping="Wrap" VerticalAlignment="Top"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>
