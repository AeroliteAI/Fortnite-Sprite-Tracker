<UserControl x:Class="FortniteSpriteTracker.Views.SpriteCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="CardBorder"
            Width="120"
            CornerRadius="8"
            BorderThickness="2"
            ClipToBounds="False"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True">

        <!-- Dynamic border color based on state -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#2A2A40"/>
                <Setter Property="Background"  Value="#0D1621"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCollected}" Value="True">
                        <Setter Property="BorderBrush" Value="#4ADE80"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsMastered}" Value="True">
                        <Setter Property="BorderBrush" Value="#F59E0B"/>
                    </DataTrigger>
                    <!-- Collected + Mastered: half green / half gold border -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsCollected}" Value="True"/>
                            <Condition Binding="{Binding IsMastered}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="BorderBrush">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4ADE80" Offset="0.0"/>
                                    <GradientStop Color="#4ADE80" Offset="0.45"/>
                                    <GradientStop Color="#F59E0B" Offset="0.55"/>
                                    <GradientStop Color="#F59E0B" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <!-- Drop shadow — static; BlurRadius animation is software-rendered and kills FPS -->
        <Border.Effect>
            <DropShadowEffect x:Name="CardShadow"
                              BlurRadius="14" ShadowDepth="4"
                              Direction="270" Color="#000000" Opacity="0.5"/>
        </Border.Effect>

        <!-- Hover: card itself stays put — background darkens, character scales/glows instead -->
        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="ImageAreaDarken"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.35" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CharacterScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.08" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CharacterScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.08" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CharacterGlow"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.45" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="ImageAreaDarken"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CharacterScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.0" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CharacterScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.0" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CharacterGlow"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.15" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="110"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- ── Image area ──────────────────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="6,6,0,0" ClipToBounds="True" Background="#0D1621">
                <Grid>
                    <!-- Darkens only the image backdrop on hover; sprite is drawn on top and stays unaffected -->
                    <Border x:Name="ImageAreaDarken" CornerRadius="6,6,0,0" Background="Black" Opacity="0" IsHitTestVisible="False"/>
                    <Image x:Name="CharacterImage"
                           Source="{Binding Image}"
                           Stretch="Uniform"
                           Margin="6"
                           RenderTransformOrigin="0.5,0.5"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="CharacterScale" ScaleX="1" ScaleY="1"/>
                        </Image.RenderTransform>
                        <Image.Effect>
                            <DropShadowEffect x:Name="CharacterGlow"
                                              Color="White" ShadowDepth="0"
                                              BlurRadius="16" Opacity="0.15"/>
                        </Image.Effect>
                    </Image>
                </Grid>
            </Border>

            <!-- Rarity badge (top-left of image) -->
            <Image Grid.Row="0"
                   Source="{Binding RarityIcon}"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Height="12"
                   Stretch="Uniform"
                   Margin="2,2,0,0"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Visibility="{Binding HasRarity, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Collected checkmark badge (top-right of image) -->
            <Border Grid.Row="0"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Background="#4ADE80" CornerRadius="0,6,0,5"
                    Padding="4,2"
                    Visibility="{Binding IsCollected, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="✓" Foreground="#0D0D15" FontSize="9" FontWeight="Bold"/>
            </Border>

            <!-- ── Display name ────────────────────────────────────── -->
            <TextBlock Grid.Row="1"
                       Text="{Binding DisplayName}"
                       Foreground="#E2E8F0"
                       FontFamily="Arial Black"
                       FontSize="10.5"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       HorizontalAlignment="Center"
                       Margin="6,5,6,3"
                       ToolTip="{Binding DisplayName}"/>

            <!-- ── Action bar ──────────────────────────────────────── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Crown / Mastery toggle -->
                <Button Grid.Column="0"
                        Command="{Binding ToggleMasteredCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="6,3,3,6"
                        Cursor="Hand"
                        ToolTip="Toggle Mastered"
                        Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CrownBd"
                                    Background="#0D1621"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Image Source="{Binding CrownImage}"
                                       Width="20" Height="20"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Margin="0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CrownBd" Property="BorderBrush" Value="#7C3AED"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Collect toggle button -->
                <Button Grid.Column="1"
                        Command="{Binding ToggleCollectedCommand}"
                        Background="#0D1621"
                        Foreground="{Binding IsCollected, Converter={StaticResource BoolToCollectedForegroundConverter}}"
                        Content="{Binding IsCollected, Converter={StaticResource BoolToCollectedTextConverter}}"
                        BorderThickness="0"
                        Margin="3,3,6,6"
                        FontFamily="Arial Black"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CollectBd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CollectBd" Property="BorderBrush" Value="#7C3AED"/>
                                    <Setter TargetName="CollectBd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CollectBd" Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

            <!-- One-time pulse glow played by code-behind when a card is just collected/mastered -->
            <Border x:Name="CollectedPulseGlow"
                    Grid.RowSpan="3" Margin="-2" CornerRadius="8" BorderThickness="3"
                    BorderBrush="#4ADE80" Background="Transparent" Opacity="0"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect Color="#4ADE80" BlurRadius="20" ShadowDepth="0" Opacity="1"/>
                </Border.Effect>
            </Border>
            <Border x:Name="MasteredPulseGlow"
                    Grid.RowSpan="3" Margin="-2" CornerRadius="8" BorderThickness="3"
                    BorderBrush="#F59E0B" Background="Transparent" Opacity="0"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect Color="#F59E0B" BlurRadius="20" ShadowDepth="0" Opacity="1"/>
                </Border.Effect>
            </Border>

        </Grid>
    </Border>
</UserControl>
