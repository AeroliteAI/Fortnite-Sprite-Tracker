<Window x:Class="FortniteSpriteTracker.Views.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options — Sprite Tracker"
        Width="540" Height="520"
        MinWidth="480" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#0D0D15"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Tab button: inactive -->
            <Style x:Key="TabBtnStyle" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="#94A3B8"/>
                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                <Setter Property="BorderBrush"     Value="Transparent"/>
                <Setter Property="Padding"         Value="20,12"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Tab button: active (purple underline + white text) -->
            <Style x:Key="TabBtnActiveStyle" TargetType="Button" BasedOn="{StaticResource TabBtnStyle}">
                <Setter Property="Foreground"  Value="#E2E8F0"/>
                <Setter Property="BorderBrush" Value="#7C3AED"/>
            </Style>

            <!-- Section heading -->
            <Style x:Key="SectionHeadStyle" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#94A3B8"/>
                <Setter Property="FontSize"    Value="10"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Margin"      Value="0,0,0,8"/>
            </Style>

            <!-- Path text -->
            <Style x:Key="PathTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground"    Value="#E2E8F0"/>
                <Setter Property="FontSize"      Value="12"/>
                <Setter Property="TextWrapping"  Value="Wrap"/>
                <Setter Property="Margin"        Value="0,0,0,10"/>
                <Setter Property="FontFamily"    Value="Consolas"/>
            </Style>

            <!-- Open folder button -->
            <Style x:Key="FolderBtnStyle" TargetType="Button">
                <Setter Property="Background"      Value="#22223A"/>
                <Setter Property="Foreground"      Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush"     Value="#3A3A5C"/>
                <Setter Property="Padding"         Value="14,8"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"  Value="#2A2A45"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#7C3AED"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3D2A6B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Instruction body text -->
            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground"   Value="#CBD5E1"/>
                <Setter Property="FontSize"     Value="12.5"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="LineHeight"   Value="22"/>
                <Setter Property="Margin"       Value="0,0,0,10"/>
            </Style>

            <!-- Mono code example text -->
            <Style x:Key="CodeTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#7C3AED"/>
                <Setter Property="FontFamily"  Value="Consolas"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="Margin"      Value="0,2,0,2"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#13131F"
                BorderBrush="#2A2A40" BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚙" Foreground="#7C3AED" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="OPTIONS" Foreground="#E2E8F0" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Tab strip ───────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#13131F"
                BorderBrush="#2A2A40" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="FilesTabBtn"        Content="FILES"        Style="{StaticResource TabBtnActiveStyle}" Click="FilesTab_Click"/>
                <Button x:Name="InstructionsTabBtn" Content="INSTRUCTIONS" Style="{StaticResource TabBtnStyle}"       Click="InstructionsTab_Click"/>
                <Button x:Name="PatchNotesTabBtn"   Content="PATCH NOTES"  Style="{StaticResource TabBtnStyle}"       Click="PatchNotesTab_Click"/>
            </StackPanel>
        </Border>

        <!-- ── Content area ────────────────────────────────────────────────── -->
        <Grid>

            <!-- ── FILES TAB ─────────────────────────────────────────────── -->
            <ScrollViewer x:Name="FilesPanel"
                          VerticalScrollBarVisibility="Auto"
                          Background="#0D0D15">
                <StackPanel Margin="28,24,28,24">

                    <TextBlock Text="DATA LOCATIONS" Style="{StaticResource SectionHeadStyle}"/>

                    <!-- Sprites folder -->
                    <Border Background="#13131F" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="📁" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Sprites Folder" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="SpritesFolderPath" Style="{StaticResource PathTextStyle}"/>
                            <Button Content="Open Sprites Folder"
                                    Style="{StaticResource FolderBtnStyle}"
                                    Click="OpenSprites_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Data folder -->
                    <Border Background="#13131F" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="💾" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Data Folder" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="DataFolderPath" Style="{StaticResource PathTextStyle}"/>
                            <Button Content="Open Data Folder"
                                    Style="{StaticResource FolderBtnStyle}"
                                    Click="OpenData_Click"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── INSTRUCTIONS TAB ──────────────────────────────────────── -->
            <ScrollViewer x:Name="InstructionsPanel"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          Background="#0D0D15">
                <StackPanel Margin="28,24,28,24">

                    <!-- How it works -->
                    <TextBlock Text="HOW IT WORKS" Style="{StaticResource SectionHeadStyle}"/>
                    <TextBlock Style="{StaticResource BodyTextStyle}">
Place <Run Foreground="#E2E8F0" FontWeight="SemiBold">.webp</Run> image files in your Sprites folder and hit <Run Foreground="#E2E8F0" FontWeight="SemiBold">Refresh</Run>. The app reads the filename, strips the rarity keyword, groups sprites by variant, and lets you track two states per sprite:
                    </TextBlock>

                    <Border Background="#13131F" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="✓" Foreground="#4ADE80" FontSize="13" FontWeight="Bold" Width="24"/>
                                <TextBlock Foreground="#E2E8F0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">Collected</TextBlock>
                            </StackPanel>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="24,0,0,12">
                                You own this sprite. Shown with a green border and a ✓ badge on the card.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image x:Name="MasteredIcon" Width="18" Height="18"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Foreground="#E2E8F0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">Mastered</TextBlock>
                            </StackPanel>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="24,0,0,0">
                                You have fully mastered this sprite. Shown with an amber border. Click the crown icon to toggle.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- File naming -->
                    <TextBlock Text="FILE NAMING SCHEME" Style="{StaticResource SectionHeadStyle}"/>
                    <TextBlock Style="{StaticResource BodyTextStyle}">
Filenames follow the pattern <Run Foreground="#E2E8F0" FontWeight="SemiBold">{Name} {RARITY}.webp</Run> for base sprites, and <Run Foreground="#E2E8F0" FontWeight="SemiBold">{Name} {RARITY} {Variant}.webp</Run> for variants. The rarity keyword is stripped from the display name automatically and shown as a badge on the card.
                    </TextBlock>

                    <!-- Rarity keywords -->
                    <Border Background="#13131F" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10">VALID RARITY KEYWORDS (must be ALL CAPS)</TextBlock>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#1A2A3A" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                    <TextBlock Text="RARE" Foreground="#38BDF8" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#2A1A3A" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                    <TextBlock Text="EPIC" Foreground="#A855F7" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#3A2A1A" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                    <TextBlock Text="LEGENDARY" Foreground="#F97316" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#3A2A00" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                    <TextBlock Text="MYTHIC" Foreground="#EAB308" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#1A3A2A" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="SPECIAL" Foreground="#4ADE80" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Naming examples -->
                    <Border Background="#13131F" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>

                            <TextBlock Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10">BASE SPRITES</TextBlock>
                            <TextBlock Style="{StaticResource CodeTextStyle}">Fire RARE.webp</TextBlock>
                            <TextBlock Foreground="#64748B" FontSize="11.5" Margin="0,4,0,8">→ Displayed as "Fire" with a RARE badge · Normal group</TextBlock>
                            <TextBlock Style="{StaticResource CodeTextStyle}">Demon EPIC.webp</TextBlock>
                            <TextBlock Foreground="#64748B" FontSize="11.5" Margin="0,4,0,8">→ Displayed as "Demon" with an EPIC badge · Normal group</TextBlock>
                            <TextBlock Style="{StaticResource CodeTextStyle}">Dream LEGENDARY.webp</TextBlock>
                            <TextBlock Foreground="#64748B" FontSize="11.5" Margin="0,4,0,8">→ Displayed as "Dream" with a LEGENDARY badge · Normal group</TextBlock>
                            <TextBlock Style="{StaticResource CodeTextStyle}">Burnt Peanut MYTHIC.webp</TextBlock>
                            <TextBlock Foreground="#64748B" FontSize="11.5" Margin="0,4,0,16">→ Displayed as "Burnt Peanut" with a MYTHIC badge · Normal group</TextBlock>

                            <TextBlock Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10">VARIANT SPRITES (use SPECIAL)</TextBlock>
                            <TextBlock Style="{StaticResource CodeTextStyle}">Fire SPECIAL Galaxy.webp</TextBlock>
                            <TextBlock Foreground="#64748B" FontSize="11.5" Margin="0,4,0,8">→ "Fire" is the base · "Galaxy" is the variant · SPECIAL badge · Galaxy group</TextBlock>
                            <TextBlock Style="{StaticResource CodeTextStyle}">Fire SPECIAL Gold.webp</TextBlock>
                            <TextBlock Foreground="#64748B" FontSize="11.5" Margin="0,4,0,8">→ Gold group</TextBlock>
                            <TextBlock Style="{StaticResource CodeTextStyle}">Fire SPECIAL Gummy.webp</TextBlock>
                            <TextBlock Foreground="#64748B" FontSize="11.5" Margin="0,4,0,0">→ Gummy group</TextBlock>

                        </StackPanel>
                    </Border>

                    <!-- Tips -->
                    <TextBlock Text="TIPS" Style="{StaticResource SectionHeadStyle}" Margin="0,4,0,8"/>
                    <Border Background="#13131F" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">• Only <Run Foreground="#E2E8F0">.webp</Run> files are loaded — other formats are ignored.</TextBlock>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">• The rarity keyword must be <Run Foreground="#E2E8F0">ALL CAPS</Run> and placed between the sprite name and variant suffix.</TextBlock>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">• The base sprite (e.g. <Run Foreground="#E2E8F0">Fire RARE.webp</Run>) must exist for variant detection to work on its SPECIAL variants.</TextBlock>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">• New variant suffixes (<Run Foreground="#E2E8F0">Crystal, Shadow, Og</Run>, etc.) create new groups automatically — no app changes needed.</TextBlock>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">• Sprites install to <Run Foreground="#E2E8F0">%LOCALAPPDATA%\Fortnite Sprite Tracker\Sprites\</Run> — use the Files tab to open this folder directly.</TextBlock>
                            <TextBlock Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap">• Hit <Run Foreground="#E2E8F0">Refresh</Run> after dropping new files into the Sprites folder.</TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── PATCH NOTES TAB ───────────────────────────────────────── -->
            <ScrollViewer x:Name="PatchNotesPanel"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          Background="#0D0D15">
                <StackPanel Margin="28,24,28,24">

                    <TextBlock Text="CURRENT VERSION" Style="{StaticResource SectionHeadStyle}"/>
                    <Border Background="#13131F" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CurrentVersionText"
                                       Foreground="#7C3AED" FontSize="16" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="CHANGELOG" Style="{StaticResource SectionHeadStyle}"/>
                    <ItemsControl x:Name="PatchNotesItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#13131F" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                       Foreground="#E2E8F0" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Date}"
                                                       Foreground="#64748B" FontSize="11"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
                                                                Background="{Binding Tag, Converter={StaticResource PatchNoteTagToBrushConverter}}"
                                                                CornerRadius="4" Padding="7,3" Margin="0,1,10,0"
                                                                VerticalAlignment="Top" HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Tag}" FontSize="10" FontWeight="Bold" Foreground="#0D0D15"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Text}"
                                                                   Foreground="#CBD5E1" FontSize="12.5"
                                                                   TextWrapping="Wrap" VerticalAlignment="Top"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>
