<Window x:Class="FortniteSpriteTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FortniteSpriteTracker.ViewModels"
        xmlns:views="clr-namespace:FortniteSpriteTracker.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Sprite Tracker"
        KeyDown="Window_KeyDown"
        Width="1340" Height="860" MinWidth="800" MinHeight="500"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                             ResizeBorderThickness="6"
                             GlassFrameThickness="0,0,0,1"
                             CornerRadius="0"
                             UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Stats bar -->
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="Auto"/>   <!-- Filter row -->
            <RowDefinition Height="*"/>      <!-- Sprite grid -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#13131F"
                BorderBrush="#2A2A40" BorderThickness="0,0,0,1"
                Padding="24,14,24,14"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SPRITE"
                               Foreground="#7C3AED"
                               FontSize="20" FontWeight="Black"/>
                    <TextBlock Text=" TRACKER"
                               Foreground="#E2E8F0"
                               FontSize="20" FontWeight="Black"/>
                </StackPanel>

                <!-- Right side: save status + loading indicator + options -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- "Saved ✓" flash -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#4ADE80" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <!-- Loading spinner -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,16,0">
                        <TextBlock Text="⟳" Foreground="#7C3AED" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Loading…" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Options button -->
                    <Button Content="⚙  Options"
                            Click="Options_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Height="30" FontSize="12"/>

                    <!-- Window caption buttons -->
                    <Button Click="Minimize_Click"
                            Style="{StaticResource CaptionButtonStyle}"
                            Margin="14,0,0,0"
                            ToolTip="Minimize">
                        <Image Source="/Assets/Minimize.png" Width="25" Height="25"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button Click="MaximizeRestore_Click"
                            Style="{StaticResource CaptionButtonStyle}"
                            Margin="6,0,0,0"
                            ToolTip="Maximize">
                        <Image Source="/Assets/Maximize.png" Width="25" Height="25"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button Click="Close_Click"
                            Style="{StaticResource CaptionButtonStyle}"
                            Margin="6,0,0,0"
                            ToolTip="Close">
                        <Image Source="/Assets/Close.png" Width="25" Height="25"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ STATS BAR ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#16162A"
                BorderBrush="#2A2A40" BorderThickness="0,0,0,1"
                Padding="24,12,24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Collection progress -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="COLLECTED"
                                   Foreground="#94A3B8" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2"
                                   FontSize="12" FontWeight="Bold">
                            <Run Foreground="#4ADE80" Text="{Binding CollectedCount, Mode=OneWay}"/>
                            <Run Foreground="#64748B" Text=" / "/>
                            <Run Foreground="#E2E8F0" Text="{Binding TotalCount, Mode=OneWay}"/>
                            <Run Foreground="#94A3B8" Text="  "/>
                            <Run Foreground="#4ADE80" Text="{Binding CollectionPercentageText, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                    <ProgressBar Grid.Row="1"
                                 Value="{Binding CollectionProgress, Mode=OneWay}"
                                 Maximum="1"
                                 Foreground="#4ADE80"/>
                </Grid>

                <!-- Divider -->
                <Border Grid.Column="1" Width="1" Background="#2A2A40" Margin="0,2"/>

                <!-- Mastery progress -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MASTERED"
                                   Foreground="#94A3B8" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2"
                                   FontSize="12" FontWeight="Bold">
                            <Run Foreground="#F59E0B" Text="{Binding MasteredCount, Mode=OneWay}"/>
                            <Run Foreground="#64748B" Text=" / "/>
                            <Run Foreground="#E2E8F0" Text="{Binding TotalCount, Mode=OneWay}"/>
                            <Run Foreground="#94A3B8" Text="  "/>
                            <Run Foreground="#F59E0B" Text="{Binding MasteryPercentageText, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                    <ProgressBar Grid.Row="1"
                                 Value="{Binding MasteryProgress, Mode=OneWay}"
                                 Maximum="1"
                                 Foreground="#F59E0B"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ══ TOOLBAR ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#13131F"
                BorderBrush="#2A2A40" BorderThickness="0,0,0,1"
                Padding="20,10,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box with placeholder -->
                <Grid Grid.Column="0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             x:Name="SearchBox"
                             VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="Search sprites…"
                               Foreground="#3A3A5C" FontSize="13"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Refresh button (disabled while loading) -->
                <Button Grid.Column="2"
                        Content="⟳  Refresh"
                        Command="{Binding RefreshSpritesCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource ToolbarButtonStyle}"/>

                <!-- Group-by toggle -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Group:" Foreground="#94A3B8" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="By Variant"
                            Command="{Binding GroupByVariantCommand}"
                            Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GroupMode}" Value="ByVariant">
                                        <Setter Property="Background" Value="#7C3AED"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="By Type"
                            Command="{Binding GroupByTypeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GroupMode}" Value="ByType">
                                        <Setter Property="Background" Value="#7C3AED"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Sort label + ComboBox -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Sort:" Foreground="#94A3B8" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="210"
                              ItemsSource="{Binding SortOptions}"
                              SelectedIndex="{Binding SelectedSortIndex}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ FILTER ROW ════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#10101C"
                BorderBrush="#2A2A40" BorderThickness="0,0,0,1"
                Padding="20,8,20,8">
            <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                <Button Content="All"
                        Command="{Binding FilterAllCommand}"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveFilter}" Value="All">
                                    <Setter Property="Background" Value="#7C3AED"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Collected"
                        Command="{Binding FilterCollectedCommand}"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveFilter}" Value="Collected">
                                    <Setter Property="Background" Value="#166534"/>
                                    <Setter Property="Foreground" Value="#4ADE80"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Not Collected"
                        Command="{Binding FilterNotCollectedCommand}"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveFilter}" Value="NotCollected">
                                    <Setter Property="Background" Value="#1A2D42"/>
                                    <Setter Property="Foreground" Value="#60A5FA"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Mastered"
                        Command="{Binding FilterMasteredCommand}"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveFilter}" Value="Mastered">
                                    <Setter Property="Background" Value="#78350F"/>
                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Not Mastered"
                        Command="{Binding FilterNotMasteredCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveFilter}" Value="NotMastered">
                                    <Setter Property="Background" Value="#2E1A1A"/>
                                    <Setter Property="Foreground" Value="#F87171"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Incomplete"
                        Command="{Binding FilterIncompleteCommand}"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveFilter}" Value="Incomplete">
                                    <Setter Property="Background" Value="#2A2A40"/>
                                    <Setter Property="Foreground" Value="#CBD5E1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

            <!-- Scale slider (right-aligned) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Size:" Foreground="#94A3B8" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider Minimum="50" Maximum="150"
                        SmallChange="5" LargeChange="10"
                        TickFrequency="5" IsSnapToTickEnabled="True"
                        Value="{Binding CardScalePercent}"
                        Width="130" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CardScalePercent, StringFormat={}{0}%}"
                           Foreground="#E2E8F0" FontSize="12"
                           Width="38" TextAlignment="Right"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            </Grid>
        </Border>

        <!-- ══ SPRITE GRID ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="4">

            <!-- Sprite cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          Padding="16,12,8,16">
                <Grid>
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding CardScaleFactor}" ScaleY="{Binding CardScaleFactor}"/>
                    </Grid.LayoutTransform>

                <!-- Outer: one entry per variant group -->
                <ItemsControl ItemsSource="{Binding DisplayedSprites}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,20">

                                <!-- Group header row (click to collapse/expand) -->
                                <Grid Margin="4,0,4,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding ToggleExpandedCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="0"
                                            HorizontalAlignment="Left"
                                            HorizontalContentAlignment="Left">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BoolToExpandArrowConverter}}"
                                                       Foreground="{Binding Color}"
                                                       FontSize="10"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Header}"
                                                       Foreground="{Binding Color}"
                                                       FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Count, StringFormat='({0})'}"
                                                       Foreground="#3A3A5C"
                                                       FontSize="12"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Divider line -->
                                    <Border Grid.Column="2"
                                            Height="1"
                                            Background="#2A2A40"
                                            VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Inner: cards in this group -->
                                <ItemsControl ItemsSource="{Binding Cards}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <views:SpriteCardView Margin="4" DataContext="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- Empty state: no sprites in folder -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="No sprites found"
                           Foreground="#E2E8F0" FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Add .webp files to the Sprites folder and click Refresh."
                           Foreground="#64748B" FontSize="13"
                           HorizontalAlignment="Center"/>
                <Button Content="⟳  Refresh Sprites"
                        Command="{Binding RefreshSpritesCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0" Padding="20,10"/>
            </StackPanel>

            <!-- Empty state: search/filter returned no results -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsFilteredEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="No sprites match"
                           Foreground="#E2E8F0" FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Try a different search term or filter."
                           Foreground="#64748B" FontSize="13"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Version label: decorative only, never intercepts clicks -->
            <TextBlock x:Name="VersionText"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,12,8"
                       Foreground="#E2E8F0" FontSize="11"
                       Opacity="0.25"
                       IsHitTestVisible="False"/>

        </Grid>
    </Grid>
</Window>
